# Add patterns of files dvc should ignore, which could improve
# the performance. Learn more at
# https://dvc.org/doc/user-guide/dvcignore

# Raw download tarballs — kept locally for reproducibility but
# not synced to the shared remote. The extracted trees
# (data/fma_small/, data/fma_metadata/) are what teammates need.
data/fma_small.zip
data/fma_metadata.zip
data/fma_small.wget.log
data/fma_metadata.wget.log

# Tracklist CSVs live in git directly, so keep DVC's hands off
# them to avoid dual tracking.
data/tracklists/

# Sample audio tracks used by the feature-extraction starter
# script also live in git, not DVC.
data/music/

# Derived / cleaned metadata (track lists, positive pairs, audio
# feature tables) is small and lives in git so teammates get it
# straight from the repo without a DVC pull.
data/clean/
